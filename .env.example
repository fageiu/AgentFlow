LLM_PROVIDER=openai-compatible
LLM_MOCK=false
LLM_FALLBACK_ON_ERROR=true

# OpenAI-compatible defaults
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# DeepSeek example
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# AgentFlow -> 企业政策知识库（真实运行默认 service；fixture 仅用于显式 Mock 评测）
RAG_MODE=service
RAG_BASE_URL=http://127.0.0.1:8000
RAG_REQUEST_TIMEOUT_MS=3000
RAG_MAX_RETRIES=1
RAG_ENABLE_RERANKER=true
RAG_MINIMUM_SCORE=0.35
RAG_MINIMUM_RERANK_SCORE=0.35
RAG_MINIMUM_VECTOR_SCORE_WITHOUT_RERANKER=0.55
RAG_ADMIN_TOKEN=agentflow-local-admin
RAG_DATABASE_URL=postgresql+asyncpg://agentflow:agentflow@127.0.0.1:5432/agentflow_rag
RAG_MODEL_CACHE_DIR=.rag-models
RAG_UPLOAD_DIR=.rag-data/uploads
