    "build": "pnpm --recursive build",
    "typecheck": "pnpm --recursive typecheck"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  }
}
