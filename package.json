{
  "name": "agentflow-sandbox",
  "version": "0.1.0",
  "private": true,
  "description": "Enterprise workflow AI agent sandbox and evaluation platform.",
  "scripts": {
    "dev": "pnpm --parallel dev",
    "dev:web": "pnpm --filter @agentflow/web dev",
